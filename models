const mongoose = require("mongoose");

const hostelSchema = new mongoose.Schema(
{
    studentName: {
        type: String,
        required: true
    },

    studentId: {
        type: String,
        required: true,
        unique: true
    },

    roomNumber: {
        type: Number,
        required: true
    },

    gender: {
        type: String,
        enum: ["Male", "Female", "Other"]
    },

    phone: {
        type: String,
        required: true
    },

    address: {
        type: String
    },

    feeStatus: {
        type: String,
        enum: ["Paid", "Pending"],
        default: "Pending"
    }
},
{
    timestamps: true
});

module.exports = mongoose.model("Hostel", hostelSchema);
